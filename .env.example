COURSE_WORKFLOW_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your_api_key

# 可选：DeepSeek 兼容接口配置
# COURSE_LLM_BASE_URL=https://api.deepseek.com
# COURSE_LLM_TEMPERATURE=0
# COURSE_LLM_TIMEOUT=120

# 必填：课程页地址。默认先打开它；需要登录时通常由站点自己跳到登录页
COURSE_URL=https://p-nju.seec.seecoder.cn/course/18

# 可选：只有课程页不能自动跳到正确登录入口时才需要配置
# COURSE_LOGIN_URL=https://your-site.example.com/login

# 可选：新站点适配/误判时再补充这些认证判定线索
# COURSE_AUTH_SUCCESS_SELECTORS=#page,#region-main,.breadcrumb
# COURSE_AUTH_SUCCESS_TEXT=课程,我的课程
# COURSE_AUTH_LOGGED_OUT_TEXT=尚未登录,请先登录
# COURSE_AUTH_INACCESSIBLE_TEXT=无权访问,禁止访问,404,not found
# COURSE_AUTH_COOKIE_NAMES=session,moodle,token,auth

# 新站点调试：true 时只探测页面和候选材料，不下载、不生成笔记
COURSE_PROBE_ONLY=false

# 可选：通用输出根目录。未设置时，相对路径默认按项目目录解析
COURSE_OUTPUT_ROOT=/path/to/your/output

# 可选：Obsidian 兼容配置。未设置 COURSE_OUTPUT_ROOT 时可继续使用
# OBSIDIAN_VAULT=/path/to/your/Obsidian Vault

# 输出目录。相对 COURSE_ATTACHMENTS_DIR 默认放在 COURSE_NOTES_DIR 下
COURSE_NOTES_DIR=SEEC
COURSE_ATTACHMENTS_DIR=Attachments
COURSE_OVERWRITE_EXISTING=false

# 可选：手动指定 pdftotext 可执行文件
# PDFTOTEXT_BIN=C:\\path\\to\\poppler\\bin\\pdftotext.exe
